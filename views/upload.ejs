<% activePage = 'upload' %>

<div class="row justify-content-center">
  <div class="col-lg-7">

    <div style="margin-bottom: 28px;">
      <h4 style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.3rem; margin-bottom:6px;">Upload Resume</h4>
      <p style="color:var(--muted); font-size:0.88rem;">PDF files only · Max 5MB · AI processing enabled</p>
    </div>

    <div class="card-dark">
      <div style="padding: 28px;">
        <form action="/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

          <div style="margin-bottom: 20px;">
            <label class="form-label-custom">Candidate Name</label>
            <input type="text" name="name" class="form-control-custom" placeholder="e.g. John Smith" required />
          </div>

          <div style="margin-bottom: 20px;">
            <label class="form-label-custom">Email Address</label>
            <input type="email" name="email" class="form-control-custom" placeholder="e.g. john@example.com" required />
          </div>


          <div style="margin-bottom: 28px;">
            <label class="form-label-custom">Resume File</label>
            <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
              <input type="file" name="resume" id="fileInput" accept=".pdf" required style="display:none;" onchange="handleFileSelect(this)" />
              <div class="upload-icon" id="uploadIconWrap">
                <i class="bi bi-cloud-upload"></i>
              </div>
              <p style="color:var(--text); font-size:0.9rem; margin-bottom:4px;" id="uploadText">Click to browse or drag & drop</p>
              <p style="color:var(--muted); font-size:0.78rem;" id="uploadSub">PDF files only, max 5MB</p>
            </div>
          </div>

          <div style="display:flex; gap:12px;">
            <button type="submit" class="btn-accent" style="flex:1; justify-content:center; padding:11px;">
              <i class="bi bi-cloud-upload"></i> Upload & Process
            </button>
            <a href="/dashboard" class="btn-ghost" style="padding:11px 20px;">Cancel</a>
          </div>

        </form>
      </div>
    </div>

    <div style="margin-top:20px; padding:14px 18px; background:rgba(79,142,255,0.06); border:1px solid rgba(79,142,255,0.15); border-radius:10px; display:flex; gap:12px; align-items:flex-start;">
      <i class="bi bi-info-circle" style="color:var(--accent); margin-top:2px; flex-shrink:0;"></i>
      <div>
        <p style="font-size:0.83rem; color:var(--text); margin-bottom:4px; font-weight:500;">How it works</p>
        <p style="font-size:0.8rem; color:var(--muted); margin:0;">Once uploaded, the resume is automatically queued for AI processing. Results will appear in the dashboard once complete.</p>
      </div>
    </div>

  </div>
</div>

<% if (typeof duplicate !== 'undefined' && duplicate) { %>
<div id="duplicateModal" style="
  position:fixed; inset:0; z-index:9999;
  background:rgba(0,0,0,0.7);
  display:flex; align-items:center; justify-content:center;
  backdrop-filter:blur(4px);
  animation: fadeIn 0.2s ease;
">
  <div style="
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:16px;
    padding:32px;
    width:100%;
    max-width:500px;
    margin:20px;
    box-shadow:0 20px 60px rgba(0,0,0,0.5);
    animation: slideUp 0.25s ease;
  ">

    <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
      <div style="width:44px; height:44px; background:rgba(251,191,36,0.15); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning); font-size:1.2rem;"></i>
      </div>
      <div>
        <h5 style="font-family:'Syne',sans-serif; font-weight:700; font-size:1rem; margin:0; color:var(--text);">Duplicate Candidate Detected</h5>
        <p style="color:var(--muted); font-size:0.78rem; margin:0;">This candidate already exists in the system</p>
      </div>
    </div>

    <div style="background:rgba(251,191,36,0.08); border:1px solid rgba(251,191,36,0.25); border-radius:10px; padding:14px 16px; margin-bottom:20px;">
      <p style="font-size:0.85rem; color:var(--text); margin:0; line-height:1.6;">
        <% if (reason === 'email') { %>
          A candidate with email <strong style="color:var(--warning);"><%= newEmail %></strong> already exists.
        <% } else { %>
          This exact resume file has already been uploaded before.
        <% } %>
        <br>You can replace the existing record with the new upload, or cancel to keep the existing one.
      </p>
    </div>

    <div style="background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:14px 16px; margin-bottom:24px;">
      <div style="font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:10px;">Existing Record</div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
        <div style="width:34px; height:34px; background:rgba(91,141,238,0.15); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:0.85rem; color:var(--accent); font-family:'Syne',sans-serif; font-weight:700; flex-shrink:0;">
          <%= duplicate.name.charAt(0).toUpperCase() %>
        </div>
        <div>
          <div style="font-weight:600; font-size:0.88rem; color:var(--text);"><%= duplicate.name %></div>
          <div style="font-size:0.75rem; color:var(--muted);"><%= duplicate.email %></div>
        </div>
        <div style="margin-left:auto;">
          <% if (duplicate.status === 'processed') { %>
            <span class="badge-processed"><i class="bi bi-check-lg me-1"></i>Processed</span>
          <% } else { %>
            <span class="badge-pending"><i class="bi bi-hourglass me-1"></i><%= duplicate.status %></span>
          <% } %>
        </div>
      </div>
      <div style="font-size:0.75rem; color:var(--muted); display:flex; align-items:center; gap:6px;">
        <i class="bi bi-calendar3"></i>
        Uploaded <%= new Date(duplicate.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
        &nbsp;·&nbsp;
        <i class="bi bi-file-pdf" style="color:#f87171;"></i>
        <%= duplicate.fileName %>
      </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:10px;">

      <form action="/upload/replace" method="POST">
        <input type="hidden" name="existingId" value="<%= duplicate.id %>">
        <input type="hidden" name="newName"    value="<%= newName %>">
        <input type="hidden" name="newEmail"   value="<%= newEmail %>">
        <input type="hidden" name="newUserId"  value="<%= newUserId %>">
        <input type="hidden" name="tempFile"   value="<%= tempFile %>">
        <input type="hidden" name="tempName"   value="<%= tempName %>">
        <button type="submit" class="btn-accent" style="width:100%; justify-content:center; padding:11px;">
          <i class="bi bi-arrow-repeat"></i> Replace Existing Resume
        </button>
      </form>

      <!-- View Profile -->
      <a href="/candidates/<%= duplicate.id %>" class="btn-ghost" style="width:100%; justify-content:center; padding:11px; text-align:center;">
        <i class="bi bi-person-lines-fill"></i> View Existing Profile
      </a>

      <!-- Cancel -->
      <form action="/upload/cancel" method="POST">
        <input type="hidden" name="tempFile" value="<%= tempFile %>">
        <button type="submit" style="width:100%; justify-content:center; padding:11px; background:transparent; border:1px solid rgba(248,113,113,0.3); color:var(--danger); border-radius:7px; font-size:0.85rem; cursor:pointer; display:flex; align-items:center; gap:6px; transition:all 0.15s;">
          <i class="bi bi-x-lg"></i> Cancel — Keep Existing
        </button>
      </form>

    </div>
  </div>
</div>

<style>
  @keyframes fadeIn  { from { opacity:0; } to { opacity:1; } }
  @keyframes slideUp { from { transform:translateY(20px); opacity:0; } to { transform:translateY(0); opacity:1; } }
</style>
<% } %>

<script>
  var zone = document.getElementById('uploadZone');

  zone.addEventListener('dragover', function(e) {
    e.preventDefault();
    zone.classList.add('dragover');
  });

  zone.addEventListener('dragleave', function() {
    zone.classList.remove('dragover');
  });

  zone.addEventListener('drop', function(e) {
    e.preventDefault();
    zone.classList.remove('dragover');
    var file = e.dataTransfer.files[0];
    if (file) {
      document.getElementById('fileInput').files = e.dataTransfer.files;
      handleFileSelect(document.getElementById('fileInput'));
    }
  });

  function handleFileSelect(input) {
    if (input.files && input.files[0]) {
      var file = input.files[0];
      document.getElementById('uploadIconWrap').innerHTML = '<i class="bi bi-file-pdf" style="color:#ef4444;"></i>';
      document.getElementById('uploadText').textContent = file.name;
      document.getElementById('uploadSub').textContent = (file.size / 1024).toFixed(1) + ' KB · PDF';
      zone.style.borderColor = 'var(--accent)';
    }
  }
</script>