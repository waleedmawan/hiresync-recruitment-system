<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'HireSync' %> | HireSync</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --bg: #1c1f2e;
      --surface: #252839;
      --surface2: #2e3248;
      --border: #3a3f5c;
      --accent: #5b8dee;
      --accent2: #9f6ef5;
      --text: #f0f2ff;
      --muted: #9ba3c0;
      --success: #34d399;
      --danger: #f87171;
      --warning: #fbbf24;
    }

    body.light {
      --bg: #f4f6fb;
      --surface: #ffffff;
      --surface2: #f0f3f9;
      --border: #e2e7f0;
      --accent: #3b6ff0;
      --text: #1a1f36;
      --muted: #8492a6;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 400;
      min-height: 100vh;
      transition: background 0.2s, color 0.2s;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: linear-gradient(rgba(91,141,238,0.05) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(91,141,238,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .card-dark {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
      position: relative;
      z-index: 1;
    }

    .btn-accent {
      background: var(--accent);
      color: #fff;
      border: none;
      padding: 8px 18px;
      border-radius: 7px;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0 2px 10px rgba(91,141,238,0.35);
    }

    .btn-accent:hover { background: #4a7de0; color: #fff; box-shadow: 0 4px 14px rgba(91,141,238,0.45); }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 7px 16px;
      border-radius: 7px;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); background: rgba(91,141,238,0.08); }

    .form-label-custom {
      font-size: 0.82rem;
      color: var(--text);
      margin-bottom: 6px;
      display: block;
      font-weight: 500;
    }

    .form-control-custom {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.88rem;
      width: 100%;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      font-family: 'DM Sans', sans-serif;
    }

    .form-control-custom:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(91,141,238,0.15);
    }

    .form-control-custom::placeholder { color: #5a6180; }

    .auth-wrapper {
      position: relative;
      z-index: 1;
    }
  </style>
</head>
<body>
  <div class="auth-wrapper">
    <%- body %>
  </div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>