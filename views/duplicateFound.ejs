<% activePage = 'upload' %>

<div id="duplicateToast" style="
  position:fixed;
  top:24px;
  right:24px;
  z-index:9999;
  background:var(--surface);
  border:1px solid rgba(251,191,36,0.4);
  border-left:4px solid var(--warning);
  border-radius:12px;
  padding:16px 20px;
  min-width:340px;
  max-width:420px;
  box-shadow:0 8px 32px rgba(0,0,0,0.3);
  display:flex;
  gap:12px;
  align-items:flex-start;
  transform:translateX(120%);
  transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
">
  <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning); font-size:1.2rem; flex-shrink:0; margin-top:1px;"></i>
  <div style="flex:1;">
    <div style="font-family:'Syne',sans-serif; font-weight:600; font-size:0.88rem; color:var(--text); margin-bottom:4px;">
      Duplicate Candidate Detected
    </div>
    <div style="font-size:0.8rem; color:var(--muted); line-height:1.5;">
      A candidate with email <strong style="color:var(--text);"><%= newEmail %></strong> already exists.<br>
      You can replace the existing record or cancel to keep the existing one.
    </div>
  </div>
  <button onclick="closeToast()" style="background:none; border:none; color:var(--muted); cursor:pointer; font-size:1rem; padding:0; flex-shrink:0;">
    <i class="bi bi-x-lg"></i>
  </button>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">

    <div style="margin-bottom:28px;">
      <h4 style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.3rem; margin-bottom:6px;">
        <i class="bi bi-exclamation-triangle" style="color:var(--warning); margin-right:8px;"></i>Duplicate Candidate Detected
      </h4>
      <p style="color:var(--muted); font-size:0.88rem;">
        A candidate with the same <%= reason === 'email' ? 'email address' : 'resume file' %> already exists in the system.
      </p>
    </div>

    <div style="background:rgba(251,191,36,0.08); border:1px solid rgba(251,191,36,0.3); border-radius:12px; padding:16px 20px; margin-bottom:20px; display:flex; gap:12px; align-items:flex-start;">
      <i class="bi bi-exclamation-triangle-fill" style="color:var(--warning); font-size:1.1rem; flex-shrink:0; margin-top:2px;"></i>
      <div>
        <p style="font-size:0.85rem; color:var(--text); font-weight:500; margin-bottom:4px;">
          A candidate with email <strong><%= newEmail %></strong> already exists.
        </p>
        <p style="font-size:0.8rem; color:var(--muted); margin:0;">
          You can replace the existing record with the new upload, or cancel to keep the existing one.
        </p>
      </div>
    </div>

    <div class="card-dark mb-3">
      <div class="card-header-custom">
        <h6><i class="bi bi-person-fill me-2" style="color:var(--muted)"></i>Existing Candidate</h6>
        <span class="badge-processed"><i class="bi bi-check-lg me-1"></i>Already in system</span>
      </div>
      <div style="padding:20px 24px;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Name</div>
            <div style="color:var(--text); font-weight:500; font-size:0.9rem;"><%= duplicate.name %></div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Email</div>
            <div style="color:var(--text); font-size:0.9rem;"><%= duplicate.email %></div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">File</div>
            <div style="color:var(--muted); font-size:0.85rem; display:flex; align-items:center; gap:6px;">
              <i class="bi bi-file-pdf" style="color:#f87171;"></i><%= duplicate.fileName %>
            </div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Status</div>
            <% if (duplicate.status === 'processed') { %>
              <span class="badge-processed"><i class="bi bi-check-lg me-1"></i>Processed</span>
            <% } else { %>
              <span class="badge-pending"><i class="bi bi-hourglass me-1"></i><%= duplicate.status %></span>
            <% } %>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Uploaded</div>
            <div style="color:var(--muted); font-size:0.85rem;">
              <%= new Date(duplicate.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
            </div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Candidate ID</div>
            <div style="color:var(--muted); font-size:0.85rem;">#<%= duplicate.id %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card-dark mb-4">
      <div class="card-header-custom">
        <h6><i class="bi bi-cloud-upload me-2" style="color:var(--accent)"></i>New Upload</h6>
        <span style="background:rgba(91,141,238,0.12); color:var(--accent); border:1px solid rgba(91,141,238,0.3); padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:500;">Pending</span>
      </div>
      <div style="padding:20px 24px;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Name</div>
            <div style="color:var(--text); font-weight:500; font-size:0.9rem;"><%= newName %></div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">Email</div>
            <div style="color:var(--text); font-size:0.9rem;"><%= newEmail %></div>
          </div>
          <div>
            <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); margin-bottom:4px;">File</div>
            <div style="color:var(--muted); font-size:0.85rem; display:flex; align-items:center; gap:6px;">
              <i class="bi bi-file-pdf" style="color:#f87171;"></i><%= tempName %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:12px;">

      <form action="/upload/replace" method="POST">
        <input type="hidden" name="existingId" value="<%= duplicate.id %>">
        <input type="hidden" name="newName"    value="<%= newName %>">
        <input type="hidden" name="newEmail"   value="<%= newEmail %>">
        <input type="hidden" name="newUserId"  value="<%= newUserId %>">
        <input type="hidden" name="tempFile"   value="<%= tempFile %>">
        <input type="hidden" name="tempName"   value="<%= tempName %>">
        <button type="submit" class="btn-accent" style="width:100%; justify-content:center; padding:12px;">
          <i class="bi bi-arrow-repeat"></i> Replace Existing Resume
        </button>
      </form>

      <a href="/candidates/<%= duplicate.id %>" class="btn-ghost" style="width:100%; justify-content:center; padding:12px; text-align:center;">
        <i class="bi bi-person-lines-fill"></i> View Existing Candidate Profile
      </a>

      <form action="/upload/cancel" method="POST">
        <input type="hidden" name="tempFile" value="<%= tempFile %>">
        <button type="submit" class="btn-danger-ghost" style="width:100%; justify-content:center; padding:12px;">
          <i class="bi bi-x-lg"></i> Cancel — Keep Existing
        </button>
      </form>

    </div>

  </div>
</div>

<script>
  window.addEventListener('load', function() {
    var toast = document.getElementById('duplicateToast');
    setTimeout(function() {
      toast.style.transform = 'translateX(0)';
    }, 300);

    setTimeout(function() {
      closeToast();
    }, 6000);
  });

  function closeToast() {
    var toast = document.getElementById('duplicateToast');
    toast.style.transform = 'translateX(120%)';
  }
</script>
