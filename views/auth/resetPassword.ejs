<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px;">
  <div style="width:100%; max-width:420px;">

    <div style="text-align:center; margin-bottom:32px;">
      <div style="display:inline-flex; align-items:center; gap:10px; margin-bottom:16px;">
        <div style="width:36px; height:36px; background:var(--accent); border-radius:8px; display:flex; align-items:center; justify-content:center;">
          <i class="bi bi-cpu" style="color:white; font-size:1.1rem;"></i>
        </div>
        <span style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.3rem; color:var(--text);">HireSync</span>
      </div>
      <div style="width:56px; height:56px; background:rgba(79,142,255,0.1); border:1px solid rgba(79,142,255,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
        <i class="bi bi-shield-lock" style="color:var(--accent); font-size:1.4rem;"></i>
      </div>
      <h4 style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.1rem; color:var(--text); margin-bottom:6px;">Reset your password</h4>
      <p style="color:var(--muted); font-size:0.83rem;">Enter the code sent to <strong style="color:var(--accent);"><%= email %></strong></p>
    </div>

    <% if (error) { %>
    <div style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:12px 16px; margin-bottom:16px; display:flex; gap:10px; align-items:center;">
      <i class="bi bi-exclamation-circle-fill" style="color:#ef4444; flex-shrink:0;"></i>
      <span style="font-size:0.85rem; color:#ef4444;"><%= error %></span>
    </div>
    <% } %>

    <div class="card-dark">
      <div style="padding:28px;">
        <form action="/auth/reset-password" method="POST">
          <input type="hidden" name="email" value="<%= email %>" />

          <div style="margin-bottom:20px;">
            <label class="form-label-custom" style="text-align:center; display:block; margin-bottom:12px;">6-digit Reset Code</label>
            <div style="display:flex; gap:10px; justify-content:center;">
              <% for(let i=0; i<6; i++) { %>
              <input type="text" maxlength="1" class="otp-box" data-index="<%= i %>" style="width:48px; height:52px; text-align:center; font-size:1.3rem; font-weight:700; background:var(--surface2); border:1px solid var(--border); border-radius:8px; color:var(--text); outline:none;" />
              <% } %>
            </div>
            <input type="hidden" name="otp" id="otpValue" />
          </div>

          <div style="margin-bottom:18px;">
            <label class="form-label-custom">New Password</label>
            <input type="password" name="password" class="form-control-custom" placeholder="Min 6 characters" required />
          </div>

          <div style="margin-bottom:24px;">
            <label class="form-label-custom">Confirm New Password</label>
            <input type="password" name="confirmPassword" class="form-control-custom" placeholder="Repeat new password" required />
          </div>

          <button type="submit" class="btn-accent" style="width:100%; justify-content:center; padding:12px;">
            <i class="bi bi-check-lg"></i> Reset Password
          </button>
        </form>

        <div style="margin-top:16px; text-align:center;">
          <form action="/auth/forgot-password" method="GET" style="display:inline;">
            <button type="submit" style="background:none; border:none; color:var(--muted); font-size:0.82rem; cursor:pointer;">
              Didn't get a code? <span style="color:var(--accent); font-weight:500;">Request new one</span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <p style="text-align:center; margin-top:20px;">
      <a href="/auth/login" style="color:var(--muted); font-size:0.82rem; text-decoration:none;">← Back to login</a>
    </p>
  </div>
</div>

<script>
  var boxes = document.querySelectorAll('.otp-box');
  boxes.forEach(function(box, i) {
    box.addEventListener('input', function() {
      if (box.value && i < boxes.length - 1) boxes[i+1].focus();
      updateHidden();
    });
    box.addEventListener('keydown', function(e) {
      if (e.key === 'Backspace' && !box.value && i > 0) boxes[i-1].focus();
    });
    box.addEventListener('focus', function() { box.style.borderColor = 'var(--accent)'; });
    box.addEventListener('blur',  function() { box.style.borderColor = 'var(--border)'; });
  });
  function updateHidden() {
    var val = '';
    boxes.forEach(function(b) { val += b.value; });
    document.getElementById('otpValue').value = val;
  }
  boxes[0] && boxes[0].focus();
</script>