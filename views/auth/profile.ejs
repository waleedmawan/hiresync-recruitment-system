<% activePage = 'profile' %>

<div class="row justify-content-center">
  <div class="col-lg-7">

    <div style="margin-bottom:28px;">
      <h4 style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.3rem; margin-bottom:6px;">My Profile</h4>
      <p style="color:var(--muted); font-size:0.88rem;">Manage your account details and password</p>
    </div>

    <div class="card-dark mb-4">
      <div style="padding:28px; display:flex; align-items:center; gap:20px;">
        <div style="width:64px; height:64px; background:var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-weight:700; font-size:1.5rem; color:white; flex-shrink:0;">
          <%= user.name ? user.name.charAt(0).toUpperCase() : '?' %>
        </div>
        <div>
          <div style="font-family:'Syne',sans-serif; font-weight:700; font-size:1.1rem; color:var(--text); margin-bottom:4px;"><%= user.name %></div>
          <div style="color:var(--muted); font-size:0.85rem; margin-bottom:6px;"><%= user.email %></div>
          <span style="background:rgba(91,141,238,0.12); color:var(--accent); border:1px solid rgba(91,141,238,0.3); padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:500; text-transform:capitalize;">
            <%= user.role %>
          </span>
        </div>
      </div>
    </div>

    <% if (success) { %>
    <div style="background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.3); border-radius:10px; padding:12px 16px; margin-bottom:16px; display:flex; gap:10px; align-items:center;">
      <i class="bi bi-check-circle-fill" style="color:#22c55e; flex-shrink:0;"></i>
      <span style="font-size:0.85rem; color:#22c55e;"><%= success %></span>
    </div>
    <% } %>
    <% if (error) { %>
    <div style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:12px 16px; margin-bottom:16px; display:flex; gap:10px; align-items:center;">
      <i class="bi bi-exclamation-circle-fill" style="color:#ef4444; flex-shrink:0;"></i>
      <span style="font-size:0.85rem; color:#ef4444;"><%= error %></span>
    </div>
    <% } %>

    <div class="card-dark">
      <div class="card-header-custom">
        <h6><i class="bi bi-pencil me-2"></i>Edit Profile</h6>
      </div>
      <div style="padding:28px;">
        <form action="/auth/profile" method="POST">

          <div style="margin-bottom:20px;">
            <label class="form-label-custom">Full Name</label>
            <input type="text" name="name" class="form-control-custom" value="<%= user.name %>" required />
          </div>

          <div style="margin-bottom:28px;">
            <label class="form-label-custom">Email Address</label>
            <input type="email" class="form-control-custom" value="<%= user.email %>" disabled style="opacity:0.5; cursor:not-allowed;" />
            <p style="font-size:0.75rem; color:var(--muted); margin-top:5px;">Email cannot be changed.</p>
          </div>

          <div style="border-top:1px solid var(--border); padding-top:24px; margin-bottom:20px;">
            <p style="font-family:'Syne',sans-serif; font-weight:600; font-size:0.85rem; color:var(--text); margin-bottom:16px;">Change Password <span style="color:var(--muted); font-weight:400; font-size:0.78rem;">(leave blank to keep current)</span></p>

            <div style="margin-bottom:16px;">
              <label class="form-label-custom">Current Password</label>
              <input type="password" name="currentPassword" class="form-control-custom" placeholder="Enter current password" />
            </div>

            <div style="margin-bottom:16px;">
              <label class="form-label-custom">New Password</label>
              <input type="password" name="newPassword" class="form-control-custom" placeholder="Min 6 characters" />
            </div>

            <div style="margin-bottom:24px;">
              <label class="form-label-custom">Confirm New Password</label>
              <input type="password" name="confirmNewPassword" class="form-control-custom" placeholder="Repeat new password" />
            </div>
          </div>

          <div style="display:flex; gap:12px;">
            <button type="submit" class="btn-accent" style="flex:1; justify-content:center; padding:11px;">
              <i class="bi bi-check-lg"></i> Save Changes
            </button>
            <a href="/dashboard" class="btn-ghost" style="padding:11px 20px;">Cancel</a>
          </div>

        </form>
      </div>
    </div>

    <div style="margin-top:20px; padding:16px 20px; background:rgba(248,113,113,0.05); border:1px solid rgba(248,113,113,0.2); border-radius:10px; display:flex; justify-content:space-between; align-items:center;">
      <div>
        <p style="font-size:0.85rem; color:var(--text); font-weight:500; margin-bottom:2px;">Sign out of your account</p>
        <p style="font-size:0.78rem; color:var(--muted); margin:0;">You will be redirected to the login page.</p>
      </div>
      <a href="/auth/logout" class="btn-danger-ghost">
        <i class="bi bi-box-arrow-right"></i> Logout
      </a>
    </div>

  </div>
</div>
